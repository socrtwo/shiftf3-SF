{
  "manifest_version": 3,
  "name": "Shift+F3 Case Changer",
  "short_name": "Shift+F3",
  "description": "Cycle the case of selected text on any webpage with Shift+F3 (lower → Title → UPPER → Sentence → iNVERT).",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Shift+F3 Case Changer",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["case-engine.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "commands": {
    "cycle-case": {
      "suggested_key": {
        "default": "Shift+F3",
        "mac": "Shift+F3"
      },
      "description": "Cycle the case of the selected text"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
